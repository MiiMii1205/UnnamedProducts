<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- This is the most appropriate target framework for the game's Unity version. -->
        <TargetFramework>netstandard2.1</TargetFramework>
        <!-- This is the GUID of your mod. Example: com.github.YourAccount.BepInExTemplate -->
        <AssemblyName>com.github.MiiMii1205.UnnamedProducts</AssemblyName>
        <!-- This is the display name of your mod. Example: BepInEx Template -->
        <AssemblyTitle>UnnamedProducts</AssemblyTitle>
        <!-- This is the version number of your mod. -->
        <Version>1.0.0</Version>
    </PropertyGroup>
    
    <ItemGroup>
        <PackageReference Include="PEAKModding.PEAKLib.Core" Version="*"/>
        <PackageReference Include="PEAKModding.PEAKLib.Items" Version="*"/>
        <PackageReference Update="Hamunii.BepInEx.AutoPlugin" Version="*"/>
        <PackageReference Include="OracleTeam-PiggyBank" Version="*" Private="False"/>
    </ItemGroup>
    
    <ItemGroup>
      <Folder Include="bundles\" />
    </ItemGroup>
    
</Project>
